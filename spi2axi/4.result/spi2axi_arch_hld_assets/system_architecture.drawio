        <!-- Clock/Reset block at bottom -->
        <mxCell id="clk_rst" value="Clock &amp; Reset / CDC Synchronizer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#8E24AA;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="460" width="300" height="40" as="geometry"/>
        </mxCell>

        <!-- Edge: clk_rst to domains -->
