        </mxCell>

        <!-- Edge: cmd_fifo -> axi_wr_ctrl -->
        <mxCell id="e_cmd_axi_wr" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666;strokeWidth=1;fontSize=8;label=cmd;" edge="1" source="cmd_fifo" target="axi_wr_ctrl" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="580" y="117"/>
            <mxPoint x="700" y="127"/>
          </mxGeometry>
        </mxCell>

        <!-- Edge: cmd_fifo -> axi_rd_ctrl -->
        <mxCell id="e_cmd_axi_rd" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666;strokeWidth=1;fontSize=8;label=cmd;" edge="1" source="cmd_fifo" target="axi_rd_ctrl" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="580" y="140"/>
            <mxPoint x="630" y="207"/>
            <mxPoint x="700" y="207"/>
          </mxGeometry>
        </mxCell>

        <!-- Edge: wdata_fifo -> axi_wr_ctrl -->
        <mxCell id="e_wdata_axi_wr" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666;strokeWidth=1;fontSize=8;label=wdata;" edge="1" source="wdata_fifo" target="axi_wr_ctrl" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="580" y="187"/>
            <mxPoint x="700" y="155"/>
