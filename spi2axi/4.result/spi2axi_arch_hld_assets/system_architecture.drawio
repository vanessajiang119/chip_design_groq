        <!-- Legend -->
        <mxCell id="legend" value="&lt;b&gt;Legend:&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#43A047&quot;&gt;Green&lt;/font&gt; = SPI Domain&lt;br&gt;&lt;font color=&quot;#1E88E5&quot;&gt;Blue&lt;/font&gt; = AXI Domain&lt;br&gt;&lt;font color=&quot;#E65100&quot;&gt;Orange&lt;/font&gt; = CDC FIFO&lt;br&gt;&lt;font color=&quot;#8E24AA&quot;&gt;Purple&lt;/font&gt; = Clock/Reset" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;align=left;" vertex="1" parent="1">
