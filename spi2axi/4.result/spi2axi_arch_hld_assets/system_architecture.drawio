<?xml version="1.0" encoding="UTF-8"?>
<mxfile>
  <diagram id="spi2axi_arch" name="System Architecture">
    <mxGraphModel dx="1143" dy="694" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="SPI2AXI Bridge System Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="500" height="30" as="geometry"/>
        </mxCell>

        <!-- SPI Clock Domain Swimlane -->
        <mxCell id="spi_domain" value="SPI Clock Domain (spi_sclk @ 50MHz)" style="swimlane;startSize=30;fillColor=#E8F5E9;strokeColor=#43A047;html=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="460" height="380" as="geometry"/>
        </mxCell>

        <!-- AXI Clock Domain Swimlane -->
        <mxCell id="axi_domain" value="AXI Clock Domain (axi_aclk @ TBD MHz)" style="swimlane;startSize=30;fillColor=#E3F2FD;strokeColor=#1E88E5;html=1;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="560" y="50" width="460" height="380" as="geometry"/>
        </mxCell>

        <!-- CDC Domain (between swimlanes) -->
        <mxCell id="cdc_label" value="CDC FIFO" style="text;html=1;strokeColor=none;fillColor=#FFF3E0;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="470" y="210" width="120" height="22" as="geometry"/>
        </mxCell>

        <!-- === SPI DOMAIN MODULES === -->

        <!-- spi_io -->
        <mxCell id="spi_io" value="spi_io&#xa;SPI I/O + Shift Reg" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;fontStyle=0;" vertex="1" parent="1">
          <mxGeometry x="70" y="100" width="130" height="50" as="geometry"/>
        </mxCell>

        <!-- SPI Pins label -->
        <mxCell id="spi_pins" value="SPI Pins&#xa;sclk/cs/sdi/sdo" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="10" y="100" width="55" height="50" as="geometry"/>
        </mxCell>

        <!-- Edge: SPI Pins -> spi_io -->
        <mxCell id="e_spi_pins_io" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666;strokeWidth=1;fontSize=9;" edge="1" source="spi_pins" target="spi_io" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- spi_cmd_decoder -->
        <mxCell id="spi_cmd_decoder" value="spi_cmd_decoder&#xa;Opcode Decode + Addr Latch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="180" width="130" height="50" as="geometry"/>
        </mxCell>

        <!-- Edge: spi_io -> spi_cmd_decoder -->
        <mxCell id="e_io_cmd" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666;strokeWidth=1;fontSize=9;" edge="1" source="spi_io" target="spi_cmd_decoder" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="135" y="150" as="sourcePoint"/>
            <mxPoint x="135" y="180" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- fsm_ctrl -->
        <mxCell id="fsm_ctrl" value="fsm_ctrl&#xa;Main State Machine&#xa;(8 states)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="240" y="130" width="130" height="60" as="geometry"/>
        </mxCell>

        <!-- Edge: spi_cmd_decoder -> fsm_ctrl -->
        <mxCell id="e_cmd_fsm" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666;strokeWidth=1;fontSize=9;" edge="1" source="spi_cmd_decoder" target="fsm_ctrl" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="200" y="205"/>
            <mxPoint x="240" y="160"/>
