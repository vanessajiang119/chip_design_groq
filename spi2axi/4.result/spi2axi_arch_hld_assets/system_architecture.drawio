          <mxGeometry x="480" y="95" width="100" height="45" as="geometry"/>
        </mxCell>

        <!-- wdata_fifo -->
        <mxCell id="wdata_fifo" value="wdata_fifo&#xa;DP:4-64, W:32" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="480" y="165" width="100" height="45" as="geometry"/>
        </mxCell>

        <!-- rdata_fifo -->
        <mxCell id="rdata_fifo" value="rdata_fifo&#xa;DP:4-64, W:32" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="480" y="235" width="100" height="45" as="geometry"/>
        </mxCell>

        <!-- Edge: spi_io -> cmd_fifo (spi_slave_if -> cmd_fifo) -->
        <mxCell id="e_cmd_fifo_spi" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666;strokeWidth=1;fontSize=8;label=cmd+addr;" edge="1" source="spi_cmd_decoder" target="cmd_fifo" parent="1">
