        </mxCell>

        <!-- Edge: axi_rd_ctrl -> rdata_fifo -->
        <mxCell id="e_axi_rd_rdata" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666;strokeWidth=1;fontSize=8;label=rdata;" edge="1" source="axi_rd_ctrl" target="rdata_fifo" parent="1">
