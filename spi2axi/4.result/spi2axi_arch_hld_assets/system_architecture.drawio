          <mxGeometry x="700" y="100" width="140" height="55" as="geometry"/>
        </mxCell>

        <!-- axi_master_if (axi_rd_ctrl) -->
        <mxCell id="axi_rd_ctrl" value="axi_rd_ctrl&#xa;AXI Read Ctrl&#xa;AR->R" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=10;" vertex="1" parent="1">
