          <mxGeometry x="700" y="270" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- Edge: csr_regfile -> wrap_addr_gen -->
        <mxCell id="e_csr_wrap" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666;strokeWidth=1;fontSize=8;label=wrap_cfg;dashed=1;" edge="1" source="csr_regfile" target="wrap_addr_gen" parent="1">
          <mxGeometry relative="1" as="geometry">
