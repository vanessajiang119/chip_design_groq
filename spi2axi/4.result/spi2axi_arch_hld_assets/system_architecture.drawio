        <!-- Edge: spi_io -> wdata_fifo -->
        <mxCell id="e_wdata_fifo_spi" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#666;strokeWidth=1;fontSize=8;label=wdata;" edge="1" source="spi_io" target="wdata_fifo" parent="1">
