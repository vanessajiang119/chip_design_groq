        <!-- AXI Bus label -->
        <mxCell id="axi_bus" value="AXI4-Lite Bus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3949AB;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="130" width="120" height="110" as="geometry"/>
        </mxCell>

        <!-- Edge: axi_wr_ctrl -> AXI Bus -->
