        <mxCell id="dep2" value="Deliverables:&#10;compiler/scheduler.py · dsl.py" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="200" width="170" height="50"/>
        </mxCell>
        <mxCell id="dep3" value="Deliverables:&#10;transformer/attention · demo" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
