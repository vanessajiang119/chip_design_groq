        <mxCell id="d2" value="Day 2: 编译器原型&#10;AM: GroqFlow安装 → 编译流程&#10;PM: 静态调度器(Python)&#10;PM: 简易DSL → Verilator联调" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4511E;fontColor=#FFFFFF;strokeColor=#BF360C;fontSize=11;" vertex="1" parent="1">
