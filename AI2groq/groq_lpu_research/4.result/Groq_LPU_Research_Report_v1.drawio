<mxfile>
  <diagram name="Groq TSP Architecture" id="arch">
    <mxGraphModel dx="1200" dy="800" grid="1" guides="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t" value="Groq TSP (Tensor Streaming Processor) Architecture" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=top;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="0" y="0" width="960" height="40"/>
        </mxCell>
        <mxCell id="p" value="ICU&#10;Instruction Control&#10;取指 + 分发" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E88E5;fontColor=#FFFFFF;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="70" width="130" height="70"/>
        </mxCell>
        <mxCell id="m" value="MEM&#10;Memory Slice&#10;SRAM 读写" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#43A047;fontColor=#FFFFFF;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="220" y="70" width="130" height="70"/>
        </mxCell>
        <mxCell id="v" value="VXM&#10;Vector Execution&#10;向量运算" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4511E;fontColor=#FFFFFF;strokeColor=#BF360C;fontSize=11;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="410" y="70" width="130" height="70"/>
        </mxCell>
        <mxCell id="x" value="MXM&#10;Matrix Execution&#10;矩阵乘累加" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8E24AA;fontColor=#FFFFFF;strokeColor=#6A1B9A;fontSize=11;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="600" y="70" width="130" height="70"/>
        </mxCell>
        <mxCell id="s" value="SXM&#10;Shift Execution&#10;移位/旋转" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00897B;fontColor=#FFFFFF;strokeColor=#00695C;fontSize=11;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="790" y="70" width="130" height="70"/>
        </mxCell>
        <mxCell id="row2" value="20 Tiles × 16 SIMD Lanes（共320通道）" style="text;html=1;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="220" y="175" width="480" height="30"/>
        </mxCell>
        <mxCell id="arr1" value="Data Flow East → West" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1E88E5;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="p" target="m">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#F4511E;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="m" target="v">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#8E24AA;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="v" target="x">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="arr4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#00897B;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="x" target="s">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="key" value="Key Specs: 14nm · 900MHz · ~230MB SRAM · ~80TB/s BW · 144 Instr Queues · 10,440 TSPs max" style="text;html=1;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;fillColor=#FFF9C4;strokeColor=#F9A825;rounded=1;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="160" y="220" width="640" height="30"/>
        </mxCell>
        <mxCell id="instr" value="Instruction Flow North → South" style="text;html=1;fontSize=11;fontColor=#666666;align=center;verticalAlign=middle;rotation=-90;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="0" y="70" width="20" height="130"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="3-Day Execution Plan" id="plan">
