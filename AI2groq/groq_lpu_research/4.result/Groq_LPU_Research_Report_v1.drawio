        <mxCell id="dep1" value="Deliverables:&#10;rtl/pe.v · rtl/systolic_array.v · tb" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="30" y="200" width="170" height="50"/>
