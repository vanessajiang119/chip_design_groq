<mxfile>
  <diagram name="TSP vs GPU Architecture" id="arch-compare">
    <mxGraphModel dx="1400" dy="900" grid="1" guides="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="Groq TSP vs NVIDIA GPU: Architecture Comparison" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=top;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="0" y="0" width="1200" height="40"/>
        </mxCell>

        <!-- Left side label: Groq TSP -->
        <mxCell id="lbl-tsp" value="Groq Tensor Streaming Processor (TSP)" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fillColor=#1E88E5;fontColor=#FFFFFF;strokeColor=#1565C0;rounded=1;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="60" width="500" height="30"/>
        </mxCell>

        <!-- TSP Slices -->
        <mxCell id="tsp-icu" value="ICU&#10;取指/译码/分发" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E88E5;fontColor=#FFFFFF;strokeColor=#1565C0;fontSize=10;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="110" width="100" height="60"/>
        </mxCell>
        <mxCell id="tsp-mem" value="MEM&#10;SRAM 220MB&#10;80TB/s BW" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#43A047;fontColor=#FFFFFF;strokeColor=#2E7D32;fontSize=10;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="150" y="110" width="100" height="60"/>
        </mxCell>
        <mxCell id="tsp-vxm" value="VXM&#10;向量运算&#10;ALU/激活" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4511E;fontColor=#FFFFFF;strokeColor=#BF360C;fontSize=10;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="270" y="110" width="100" height="60"/>
        </mxCell>
        <mxCell id="tsp-mxm" value="MXM&#10;矩阵乘累加&#10;409.6K MAC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8E24AA;fontColor=#FFFFFF;strokeColor=#6A1B9A;fontSize=10;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="390" y="110" width="100" height="60"/>
        </mxCell>
        <mxCell id="tsp-sxm" value="SXM&#10;移位/路由&#10;C2C I/O" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#00897B;fontColor=#FFFFFF;strokeColor=#00695C;fontSize=10;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="510" y="110" width="100" height="60"/>
        </mxCell>

        <!-- TSP Data flow arrows -->
        <mxCell id="tsp-arr1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#1E88E5;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="tsp-icu" target="tsp-mem">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="tsp-arr2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#F4511E;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="tsp-mem" target="tsp-vxm">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="tsp-arr3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#8E24AA;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="tsp-vxm" target="tsp-mxm">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="tsp-arr4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#00897B;strokeWidth=2;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="tsp-mxm" target="tsp-sxm">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- TSP Feature Box -->
        <mxCell id="tsp-feat" value="Key Features:&#10;• 20 Super Lanes × 16 SIMD = 320 lanes&#10;• Deterministic execution (no caches/BP/arbiters)&#10;• Data flow East→West, Instructions North→South&#10;• Compiler-controlled 144 instr queues&#10;• TruePoint 100-bit accumulation&#10;• No DRAM, no cache coherence" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=#E3F2FD;strokeColor=#1E88E5;rounded=1;whiteSpace=wrap;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="190" width="580" height="100"/>
        </mxCell>

        <!-- Right side label: NVIDIA GPU -->
        <mxCell id="lbl-gpu" value="NVIDIA GPU (SM + Tensor Core)" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fillColor=#76B900;fontColor=#FFFFFF;strokeColor=#3B5C00;rounded=1;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="640" y="60" width="530" height="30"/>
        </mxCell>

        <!-- GPU SM Components -->
        <mxCell id="gpu-wrap" value="Streaming Multiprocessor (SM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F6F8FA;strokeColor=#76B900;strokeWidth=2;fontSize=11;fontStyle=1;dashed=1;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="640" y="110" width="530" height="140"/>
        </mxCell>
        <mxCell id="gpu-sched" value="Warp Schedulers&#10;(4 per SM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#76B900;fontColor=#FFFFFF;strokeColor=#3B5C00;fontSize=9;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="660" y="125" width="110" height="40"/>
        </mxCell>
        <mxCell id="gpu-cores" value="CUDA Cores&#10;16,896 (H100)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2196F3;fontColor=#FFFFFF;strokeColor=#1565C0;fontSize=9;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="790" y="125" width="110" height="40"/>
        </mxCell>
        <mxCell id="gpu-tc" value="Tensor Cores&#10;4th Gen (H100)&#10;~2,000 TFLOPS FP8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8E24AA;fontColor=#FFFFFF;strokeColor=#6A1B9A;fontSize=9;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="920" y="125" width="110" height="40"/>
        </mxCell>
        <mxCell id="gpu-mem" value="Shared Mem/L1 + RegFile&#10;L2 Cache (50MB)&#10;HBM3 (80GB, 3TB/s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;fontColor=#FFFFFF;strokeColor=#E65100;fontSize=9;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="1050" y="125" width="110" height="40"/>
        </mxCell>

        <!-- GPU Feature Box -->
        <mxCell id="gpu-feat" value="Key Features:&#10;• SIMT model — 32 threads/warp, thousands of threads/SM&#10;• Dynamic warp scheduling — zero-cost context switch&#10;• CUDA Cores (scalar) + Tensor Cores (matrix MMA)&#10;• HBM + L1/L2 cache hierarchy&#10;• Latency hiding via massive thread concurrency&#10;• Programmable via CUDA/Triton/OpenCL" style="text;html=1;fontSize=10;align=left;verticalAlign=middle;fillColor=#F0FCE8;strokeColor=#76B900;rounded=1;whiteSpace=wrap;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="640" y="190" width="530" height="100"/>
        </mxCell>

        <!-- Comparison Table -->
        <mxCell id="comp-title" value="Architecture Comparison Summary" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="310" width="1140" height="30"/>
        </mxCell>

        <!-- Header Row -->
        <mxCell id="h-dr" value="Dimension" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1A1A1A;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="350" width="280" height="30"/>
        </mxCell>
        <mxCell id="h-tsp" value="Groq TSP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E88E5;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="310" y="350" width="430" height="30"/>
        </mxCell>
        <mxCell id="h-gpu" value="NVIDIA GPU" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#76B900;fontColor=#FFFFFF;fontSize=10;fontStyle=1;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="740" y="350" width="430" height="30"/>
        </mxCell>

        <!-- Row 1: Execution Model -->
        <mxCell id="r1-1" value="Execution Model" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="380" width="280" height="28"/>
        </mxCell>
        <mxCell id="r1-2" value="Deterministic — compile-time scheduling" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="310" y="380" width="430" height="28"/>
        </mxCell>
        <mxCell id="r1-3" value="Dynamic — hardware warp scheduling" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="740" y="380" width="430" height="28"/>
        </mxCell>

        <!-- Row 2: Memory -->
        <mxCell id="r2-1" value="Memory" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="408" width="280" height="28"/>
        </mxCell>
        <mxCell id="r2-2" value="220MB SRAM, 80TB/s, no DRAM" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="310" y="408" width="430" height="28"/>
        </mxCell>
        <mxCell id="r2-3" value="80-192GB HBM, 3-8TB/s, L1+L2 cache" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="740" y="408" width="430" height="28"/>
        </mxCell>

        <!-- Row 3: Matrix Compute -->
        <mxCell id="r3-1" value="Matrix Compute" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="436" width="280" height="28"/>
        </mxCell>
        <mxCell id="r3-2" value="409,600 MACs (systolic stream)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="310" y="436" width="430" height="28"/>
        </mxCell>
        <mxCell id="r3-3" value="528 Tensor Cores (systolic array)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="740" y="436" width="430" height="28"/>
        </mxCell>

        <!-- Row 4: Programming -->
        <mxCell id="r4-1" value="Programming" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#FFFFFF;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="464" width="280" height="28"/>
        </mxCell>
        <mxCell id="r4-2" value="GroqFlow / MLIR (static compilation)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="310" y="464" width="430" height="28"/>
        </mxCell>
        <mxCell id="r4-3" value="CUDA / Triton / OpenCL (runtime dispatch)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="740" y="464" width="430" height="28"/>
        </mxCell>

        <!-- Row 5: Batch=1 -->
        <mxCell id="r5-1" value="Batch=1 Efficiency" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="492" width="280" height="28"/>
        </mxCell>
        <mxCell id="r5-2" value="Excellent (streaming keeps all MACs fed)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="310" y="492" width="430" height="28"/>
        </mxCell>
        <mxCell id="r5-3" value="Poor (tensor cores underutilized)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="740" y="492" width="430" height="28"/>
        </mxCell>

        <!-- Row 6: Latency -->
        <mxCell id="r6-1" value="Latency Jitter" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#FFFFFF;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="520" width="280" height="28"/>
        </mxCell>
        <mxCell id="r6-2" value="&lt; 1µs (fully deterministic)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="310" y="520" width="430" height="28"/>
        </mxCell>
        <mxCell id="r6-3" value="Milliseconds+ (cache/HBM jitter)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="740" y="520" width="430" height="28"/>
        </mxCell>

        <!-- Row 7: Energy -->
        <mxCell id="r7-1" value="Energy Efficiency" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="548" width="280" height="28"/>
        </mxCell>
        <mxCell id="r7-2" value="1-3 J/token (~10x better)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="310" y="548" width="430" height="28"/>
        </mxCell>
        <mxCell id="r7-3" value="10-30 J/token" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="740" y="548" width="430" height="28"/>
        </mxCell>

        <!-- Row 8: Large Model -->
        <mxCell id="r8-1" value="Large Model Capacity" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#FFFFFF;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="576" width="280" height="28"/>
        </mxCell>
        <mxCell id="r8-2" value="Limited (~230MB), needs 100s of chips" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="310" y="576" width="430" height="28"/>
        </mxCell>
        <mxCell id="r8-3" value="80-192GB/chip, fits 70B+ models" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#FFFFFF;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="740" y="576" width="430" height="28"/>
        </mxCell>

        <!-- Row 9: Ecosystem -->
        <mxCell id="r9-1" value="Software Ecosystem" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fontStyle=1;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="604" width="280" height="28"/>
        </mxCell>
        <mxCell id="r9-2" value="Early stage (2M+ devs, GroqCloud)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="310" y="604" width="430" height="28"/>
        </mxCell>
        <mxCell id="r9-3" value="Mature (4M+ devs, 15+ years CUDA)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#F6F8FA;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="740" y="604" width="430" height="28"/>
        </mxCell>

        <!-- Bottom summary box -->
        <mxCell id="summary" value="Bottom Line: Groq TSP wins on latency, determinism, energy efficiency for inference. GPU wins on capacity, flexibility, ecosystem maturity, training. The NVIDIA-Groq $20B deal (Dec 2025) confirms both architectures are converging." style="text;html=1;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;fillColor=#FFF9C4;strokeColor=#F9A825;rounded=1;whiteSpace=wrap;" vertex="1" parent="1" connectable="0">
          <mxGeometry x="30" y="650" width="1140" height="40"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
